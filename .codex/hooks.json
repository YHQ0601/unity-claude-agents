{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/bootstrap-session.sh\"",
            "timeout": 30,
            "statusMessage": "Loading Unity workflow context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.claude/hooks/route-user-prompt.sh\"",
            "timeout": 30,
            "statusMessage": "Routing Unity workflow hints"
          }
        ]
      }
    ]
  }
}
